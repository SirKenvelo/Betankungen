{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build (FPC → bin/)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "mkdir -p bin build && fpc -Mobjfpc -Sh -gl -gw -FEbin -FUbuild -Fuunits src/Betankungen.lpr"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$gcc",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Clean (bin/build/.o/.ppu)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "rm -rf build bin && find . -name '*.o' -delete && find . -name '*.ppu' -delete"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
